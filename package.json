{
  "name": "salesforce-app",
  "private": true,
  "version": "1.0.0",
  "description": "Salesforce App",
  "type": "module",
  "scripts": {
    "lint": "eslint **/{aura,lwc}/**/*.js",
    "test": "npm run test:unit",
    "test:unit": "sfdx-lwc-jest",
    "test:unit:watch": "sfdx-lwc-jest --watch",
    "test:unit:debug": "sfdx-lwc-jest --debug",
    "test:unit:coverage": "sfdx-lwc-jest --coverage",
    "prettier": "prettier --write \"**/*.{cls,cmp,component,css,html,js,json,md,page,trigger,xml,yaml,yml}\"",
    "prettier:verify": "prettier --check \"**/*.{cls,cmp,component,css,html,js,json,md,page,trigger,xml,yaml,yml}\"",
    "prepare": "husky || true",
    "precommit": "lint-staged",
    "test:e2e": "rm -rf allure-results && playwright test",
    "test:non-ida": "rm -rf allure-results && playwright test tests/non-ida/01-account-mgmt.spec.js tests/non-ida/02-lead-mgmt.spec.js tests/non-ida/03-oppty-mgmt.spec.js",
    "test:sit-mvp3": "rm -rf allure-results && PW_TIMEOUT=120 playwright test tests/sit-mvp3/01-opportunity-mgmt.spec.js tests/sit-mvp3/02-quote-add-product.spec.js tests/sit-mvp3/03-quote-number-mgmt.spec.js tests/sit-mvp3/04-quote-finalization.spec.js tests/sit-mvp3/05-contract-mgmt.spec.js tests/sit-mvp3/06-contract-approval.spec.js tests/sit-mvp3/07-quote-enrich-activation.spec.js tests/sit-mvp3/08-order-generation.spec.js tests/sit-mvp3/09-work-order-pre-activation.spec.js tests/sit-mvp3/10-order-service-activation.spec.js tests/sit-mvp3/11-order-billing.spec.js tests/sit-mvp3/12-work-order-testing.spec.js tests/sit-mvp3/13-order-completion.spec.js --workers=1",
    "test:sit-mvp3:state-reset": "node -e \"import('./utils/runtime-state.js').then(m => m.clearState())\"",
    "test:sit-mvp3:api-only": "PW_TIMEOUT=120 playwright test tests/sit-mvp3/01-opportunity-mgmt.spec.js tests/sit-mvp3/10-order-service-activation.spec.js tests/sit-mvp3/11-order-billing.spec.js tests/sit-mvp3/13-order-completion.spec.js --workers=1",
    "run-server": "node utils/run-server.js",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report --port 8100",
    "allure:serve": "allure serve allure-results --port 8100",
    "allure:clear": "rm -rf allure-results"
  },
  "devDependencies": {
    "@lwc/eslint-plugin-lwc": "^3.1.0",
    "@playwright/test": "^1.59.1",
    "@prettier/plugin-xml": "^3.4.1",
    "@salesforce/eslint-config-lwc": "^4.0.0",
    "@salesforce/eslint-plugin-aura": "^3.0.0",
    "@salesforce/eslint-plugin-lightning": "^2.0.0",
    "@salesforce/sfdx-lwc-jest": "^7.0.2",
    "@types/node": "^25.5.2",
    "allure-commandline": "^2.38.1",
    "allure-playwright": "^3.7.1",
    "eslint": "^9.29.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jest": "^28.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "prettier": "^3.5.3",
    "prettier-plugin-apex": "^2.2.6"
  },
  "lint-staged": {
    "**/*.{cls,cmp,component,css,html,js,json,md,page,trigger,xml,yaml,yml}": [
      "prettier --write"
    ],
    "**/{aura,lwc}/**/*.js": [
      "eslint"
    ],
    "**/lwc/**": [
      "sfdx-lwc-jest -- --bail --findRelatedTests --passWithNoTests"
    ]
  },
  "dependencies": {
    "@playwright/test": "^1.59.1",
    "allure-commandline": "^2.38.1",
    "allure-js-commons": "^3.7.1",
    "allure-playwright": "^3.7.1",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "pg": "^8.20.0"
  }
}
